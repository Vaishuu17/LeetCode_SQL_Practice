-- Problem: Second Highest Salary
-- LeetCode ID: 176
-- Difficulty: Medium
-- Topic: DISTINCT,WINDOW FUNCTION,DENSE_RANK()
-- Link: https://leetcode.com/problems/second-highest-salary/

SELECT
    (SELECT salary
     FROM (
         SELECT salary,
                DENSE_RANK() OVER (ORDER BY salary DESC) AS rnk
         FROM Employee
     ) t
     WHERE rnk = 2
     LIMIT 1
    ) AS SecondHighestSalary;
